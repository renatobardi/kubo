# .env.example — Kubo · copie para .env e preencha (NUNCA commite .env).
# Segredos só por referência (invariante 8): valores reais vivem só no .env local
# ou no secret manager da OCI, jamais neste arquivo nem em qualquer commit.

# --- SurrealDB ---
SURREAL_USER=root
SURREAL_PASS=troque-esta-senha
SURREAL_NS=kubo
SURREAL_DB=kubo

# --- Timezone ---
# Alinha os timestamps de log do scheduler ao horário do schedules.yaml.
TZ=America/Sao_Paulo

# --- Backup ---
# Sem upload externo na fase 1 (D2 emendada, ADR-0011): o sidecar do compose dumpa
# em /backups (encadeado até ~/backups/kubo do host no deploy LXC) com retenção de
# 7 dias. O rsync do dono puxa do host para o Mac. Bucket OCI fica para PRD.

# --- Deploy DEV no LXC (oute-server) ---
# Descomente SÓ no kubo-test para ativar o overlay compose.dev-lxc.yml (backup em
# bind no host). Deixe COMENTADO em PRD/OCI — lá o compose principal sobe sozinho.
# O default seguro do example é PRD; o operador DEV descomenta conscientemente.
# COMPOSE_FILE=docker-compose.yml:compose.dev-lxc.yml
