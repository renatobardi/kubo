# .env.example — Kubo · copie para .env e preencha (NUNCA commite .env).
# Segredos só por referência (invariante 8): valores reais vivem só no .env local
# ou no secret manager da OCI, jamais neste arquivo nem em qualquer commit.

# --- SurrealDB ---
SURREAL_USER=root
SURREAL_PASS=troque-esta-senha
SURREAL_NS=kubo
SURREAL_DB=kubo

# --- Backup → OCI Object Storage ---
# URL de Pre-Authenticated Request (PAR) de escrita do bucket, terminada em "/".
# Vazio = backup só local (sem upload). Gerada no console da OCI, nunca no repo.
# Ex.: https://objectstorage.<region>.oraclecloud.com/p/<par-token>/n/<ns>/b/<bucket>/o/
OCI_UPLOAD_PAR_URL=
